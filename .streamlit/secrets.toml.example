# Streamlit Cloud Secrets Configuration
# =====================================
# This file shows the format for Streamlit Cloud secrets.
# DO NOT commit actual secrets to Git!
#
# For Streamlit Cloud deployment:
# 1. Go to your app's dashboard on share.streamlit.io
# 2. Click "Settings" -> "Secrets"
# 3. Paste your secrets in TOML format (like below)
#
# For local development:
# - Use a .env file instead (see .env.example)

# Firecrawl API Key (required for contact discovery)
FIRECRAWL_API_KEY = "fc-your-api-key-here"

# Optional: Override default API URL
# FIRECRAWL_API_URL = "https://api.firecrawl.dev/v2"

# Optional: Timeout in milliseconds
# FIRECRAWL_TIMEOUT = "60000"
